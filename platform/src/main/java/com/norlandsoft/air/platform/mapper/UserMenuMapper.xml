<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.norlandsoft.air.platform.mapper.UserMenuMapper">

  <resultMap id="BaseResultMap" type="com.norlandsoft.air.platform.model.entity.UserMenu">
    <id column="id" property="id" jdbcType="VARCHAR"/>
    <result column="name" property="name" jdbcType="VARCHAR"/>
    <result column="icon" property="icon" jdbcType="VARCHAR"/>
    <result column="parent" property="parent" jdbcType="VARCHAR"/>
    <result column="sort_order" property="sortOrder" jdbcType="INTEGER"/>
  </resultMap>

  <sql id="Base_Column_List">
    id, name, icon, parent, sort_order
  </sql>

  <!-- 根据ID查询菜单 -->
  <select id="selectById" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List"/>
    FROM user_menu WHERE id = #{id}
  </select>

  <!-- 查询所有菜单 -->
  <select id="selectAll" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List"/>
    FROM user_menu ORDER BY parent ASC, sort_order ASC, id ASC
  </select>

  <!-- 根据父菜单ID查询子菜单 -->
  <select id="selectByParent" resultMap="BaseResultMap">
    SELECT <include refid="Base_Column_List"/>
    FROM user_menu WHERE parent = #{parent} ORDER BY sort_order ASC, id ASC
  </select>

  <!-- 根据条件查询菜单 -->
  <select id="selectByCondition" resultMap="BaseResultMap" parameterType="com.norlandsoft.air.platform.model.entity.UserMenu">
    SELECT <include refid="Base_Column_List"/>
    FROM user_menu
    <where>
      <if test="id != null and id != ''">AND id = #{id}</if>
      <if test="name != null and name != ''">AND name LIKE CONCAT('%', #{name}, '%')</if>
      <if test="icon != null and icon != ''">AND icon = #{icon}</if>
      <if test="parent != null and parent != ''">AND parent = #{parent}</if>
      <if test="sortOrder != null">AND sort_order = #{sortOrder}</if>
    </where>
    ORDER BY parent ASC, sort_order ASC, id ASC
  </select>

  <!-- 插入菜单 -->
  <insert id="insert" parameterType="com.norlandsoft.air.platform.model.entity.UserMenu">
    INSERT INTO user_menu (id, name, icon, parent, sort_order)
    VALUES (#{id}, #{name}, #{icon}, #{parent}, #{sortOrder})
  </insert>

  <!-- 更新菜单（仅更新非空字段） -->
  <update id="update" parameterType="com.norlandsoft.air.platform.model.entity.UserMenu">
    UPDATE user_menu
    <set>
      <if test="name != null and name != ''">name = #{name},</if>
      <if test="icon != null and icon != ''">icon = #{icon},</if>
      <if test="parent != null and parent != ''">parent = #{parent},</if>
      <if test="sortOrder != null">sort_order = #{sortOrder},</if>
    </set>
    WHERE id = #{id}
  </update>

  <!-- 根据ID删除菜单 -->
  <delete id="deleteById">
    DELETE FROM user_menu WHERE id = #{id}
  </delete>

  <!-- 统计菜单总数 -->
  <select id="count" resultType="long">
    SELECT COUNT(*) FROM user_menu
  </select>

</mapper>
